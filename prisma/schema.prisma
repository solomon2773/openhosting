// OpenHosting domain model — Postgres (works with Supabase; DIRECT_URL is used
// for migrations when connecting through Supabase's pooler).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Users & auth ────────────────────────────────────────────────────────────

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  password        String
  firstName       String
  lastName        String
  companyName     String?
  address         String?
  city            String?
  state           String?
  zip             String?
  country         String?
  phone           String?
  credits         Decimal   @default(0) @db.Decimal(12, 2) // in base currency
  currency        String? // preferred display/charge currency
  vatId           String?
  vatValidatedAt  DateTime?
  referredByAffiliateId String?
  referredBy      Affiliate? @relation("ReferredUsers", fields: [referredByAffiliateId], references: [id], onDelete: SetNull)
  emailVerifiedAt DateTime?
  totpSecret      String?
  totpEnabledAt   DateTime?
  roleId          String?
  role            Role?     @relation(fields: [roleId], references: [id], onDelete: SetNull)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  sessions        Session[]
  orders          Order[]
  services        Service[]
  invoices        Invoice[]
  tickets         Ticket[]
  ticketMessages  TicketMessage[]
  assignedTickets Ticket[]        @relation("AssignedTickets")
  apiKeys         ApiKey[]
  auditLogs       AuditLog[]
  tokens          VerificationToken[]
  paymentMethods  StoredPaymentMethod[]
  notifications   Notification[]
  notificationPreferences NotificationPreference[]
  affiliate       Affiliate?
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String // invoice_created, invoice_paid, service_activated, …
  title     String
  body      String?
  link      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
}

// Per-user, per-event channel opt-outs (defaults to both channels on).
model NotificationPreference {
  userId String
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type   String
  email  Boolean @default(true)
  inApp  Boolean @default(true)

  @@id([userId, type])
}

// A card/mandate stored at a gateway for off-session auto-charging.
model StoredPaymentMethod {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  gateway    String // driver slug, e.g. "stripe"
  customerId String // gateway-side customer reference
  methodId   String // gateway-side payment method reference
  brand      String?
  last4      String?
  expMonth   Int?
  expYear    Int?
  isDefault  Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@index([userId])
}

// Staff role. A user with any role is staff; permissions ["*"] = full admin.
model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  permissions Json     @default("[]")
  users       User[]
  createdAt   DateTime @default(now())
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
}

enum TokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
  TWO_FACTOR
}

model VerificationToken {
  id        String    @id @default(cuid())
  token     String    @unique
  type      TokenType
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime  @default(now())
}

// ── Catalog ─────────────────────────────────────────────────────────────────

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  image       String?
  sortOrder   Int       @default(0)
  hidden      Boolean   @default(false)
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  image       String?
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  // null = unlimited stock
  stock         Int?
  hidden        Boolean @default(false)
  sortOrder     Int     @default(0)
  allowQuantity Boolean @default(false)
  // Server-provisioning extension that fulfils this product, plus its per-product
  // settings (e.g. Pterodactyl egg/limits).
  serverExtensionId String?
  serverExtension   Extension? @relation(fields: [serverExtensionId], references: [id], onDelete: SetNull)
  serverConfig      Json?
  // per-product affiliate commission override (null = program default)
  affiliateCommissionType  CommissionType?
  affiliateCommissionValue Decimal?        @db.Decimal(12, 2)

  prices        ProductPrice[]
  configOptions ConfigOption[]
  orderItems    OrderItem[]
  services      Service[]
  coupons       Coupon[]
  upgradesFrom  ProductUpgrade[] @relation("UpgradeFrom")
  upgradesTo    ProductUpgrade[] @relation("UpgradeTo")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

enum BillingCycle {
  ONE_TIME
  MONTHLY
  QUARTERLY
  SEMI_ANNUALLY
  ANNUALLY
  BIENNIALLY
}

model ProductPrice {
  id        String       @id @default(cuid())
  productId String
  product   Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  cycle     BillingCycle
  price     Decimal      @db.Decimal(12, 2)
  setupFee  Decimal      @default(0) @db.Decimal(12, 2)

  @@unique([productId, cycle])
}

// Configurable options (e.g. RAM, disk) with priced values.
model ConfigOption {
  id        String              @id @default(cuid())
  productId String
  product   Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String
  envKey    String? // variable name passed to the provisioning extension
  sortOrder Int                 @default(0)
  values    ConfigOptionValue[]
}

model ConfigOptionValue {
  id        String       @id @default(cuid())
  optionId  String
  option    ConfigOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  label     String
  value     String
  // monthly price delta; scaled to the chosen cycle at checkout
  price     Decimal      @default(0) @db.Decimal(12, 2)
  sortOrder Int          @default(0)
}

// ── Orders & services ───────────────────────────────────────────────────────

// Admin-defined allowed upgrade path between two products.
model ProductUpgrade {
  id            String  @id @default(cuid())
  fromProductId String
  fromProduct   Product @relation("UpgradeFrom", fields: [fromProductId], references: [id], onDelete: Cascade)
  toProductId   String
  toProduct     Product @relation("UpgradeTo", fields: [toProductId], references: [id], onDelete: Cascade)

  @@unique([fromProductId, toProductId])
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
}

enum ReviewStatus {
  AUTO_APPROVED
  PENDING_REVIEW
  APPROVED
  REJECTED
}

model Order {
  id           String       @id @default(cuid())
  number       Int          @unique @default(autoincrement())
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  status       OrderStatus  @default(PENDING)
  reviewStatus ReviewStatus @default(AUTO_APPROVED)
  ip           String?
  riskScore    Int?
  riskNotes    String?
  currency  String      @default("USD")
  subtotal  Decimal     @default(0) @db.Decimal(12, 2)
  discount  Decimal     @default(0) @db.Decimal(12, 2)
  tax       Decimal     @default(0) @db.Decimal(12, 2)
  total     Decimal     @default(0) @db.Decimal(12, 2)
  couponId  String?
  coupon    Coupon?     @relation(fields: [couponId], references: [id], onDelete: SetNull)
  items     OrderItem[]
  services  Service[]
  invoices  Invoice[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([userId])
}

model OrderItem {
  id        String       @id @default(cuid())
  orderId   String
  order     Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product      @relation(fields: [productId], references: [id])
  cycle     BillingCycle
  quantity  Int          @default(1)
  unitPrice Decimal      @db.Decimal(12, 2)
  setupFee  Decimal      @default(0) @db.Decimal(12, 2)
  // chosen config option values: [{option, value, label, price}]
  config    Json?
}

enum ServiceStatus {
  PENDING
  ACTIVE
  SUSPENDED
  CANCELLED
  EXPIRED
}

// A provisioned instance of a product owned by a user.
model Service {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product       @relation(fields: [productId], references: [id])
  orderId   String?
  order     Order?        @relation(fields: [orderId], references: [id], onDelete: SetNull)
  status    ServiceStatus @default(PENDING)
  cycle     BillingCycle
  price     Decimal       @db.Decimal(12, 2)
  currency  String? // locked at order time; null = base currency
  quantity  Int           @default(1)
  config    Json?
  // id of the resource created by the provisioning extension
  externalId  String?
  expiresAt   DateTime?
  suspendedAt DateTime?
  cancelledAt DateTime?
  // customer requested cancellation at the end of the paid period
  cancelAtPeriodEnd Boolean @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  invoiceItems InvoiceItem[]

  @@index([userId])
  @@index([status, expiresAt])
}

// ── Billing ─────────────────────────────────────────────────────────────────

enum InvoiceStatus {
  PENDING
  PAID
  CANCELLED
  REFUNDED
}

model Invoice {
  id        String        @id @default(cuid())
  number    Int           @unique @default(autoincrement())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderId   String?
  order     Order?        @relation(fields: [orderId], references: [id], onDelete: SetNull)
  status    InvoiceStatus @default(PENDING)
  currency  String        @default("USD")
  subtotal  Decimal       @default(0) @db.Decimal(12, 2)
  discount  Decimal       @default(0) @db.Decimal(12, 2)
  tax       Decimal       @default(0) @db.Decimal(12, 2)
  total     Decimal       @default(0) @db.Decimal(12, 2)
  dueAt     DateTime?
  paidAt    DateTime?
  // failed off-session charge attempts (capped by the billing engine)
  autoChargeAttempts Int @default(0)
  items     InvoiceItem[]
  payments  Payment[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([userId])
  @@index([status, dueAt])
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Int      @default(1)
  unitPrice   Decimal  @db.Decimal(12, 2)
  serviceId   String?
  service     Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  // side effects on payment, e.g. {"upgradeServiceId": "...", "toProductId": "...", "newPrice": 12.5}
  metadata    Json?
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model Payment {
  id            String        @id @default(cuid())
  invoiceId     String
  invoice       Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  gateway       String // extension slug, or "credits" / "manual"
  amount        Decimal       @db.Decimal(12, 2)
  currency      String        @default("USD")
  status        PaymentStatus @default(PENDING)
  transactionId String? // gateway-side reference
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([invoiceId])
}

// ── Promotions & taxes ──────────────────────────────────────────────────────

enum CouponType {
  PERCENT
  FIXED
}

model Coupon {
  id        String     @id @default(cuid())
  code      String     @unique
  type      CouponType
  value     Decimal    @db.Decimal(12, 2)
  maxUses   Int? // null = unlimited
  uses      Int        @default(0)
  expiresAt DateTime?
  // empty = applies to every product
  products  Product[]
  orders    Order[]
  createdAt DateTime   @default(now())
}

enum BanType {
  EMAIL
  EMAIL_DOMAIN
  IP
  COUNTRY
}

// Fraud ban lists checked at registration and checkout.
model BanRule {
  id        String   @id @default(cuid())
  type      BanType
  value     String
  reason    String?
  createdAt DateTime @default(now())

  @@unique([type, value])
}

model TaxRate {
  id      String  @id @default(cuid())
  name    String
  rate    Decimal @db.Decimal(5, 2) // percent
  country String? // null = fallback for all countries
}

// Additional display/charge currencies. The base currency lives in settings
// (`currency`); `rate` is units of this currency per 1 unit of base.
model Currency {
  code    String  @id // ISO 4217, e.g. EUR
  symbol  String?
  rate    Decimal @db.Decimal(12, 6)
  enabled Boolean @default(true)
}

// ── Support ─────────────────────────────────────────────────────────────────

enum TicketStatus {
  OPEN
  ANSWERED
  CUSTOMER_REPLY
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
}

model Ticket {
  id           String          @id @default(cuid())
  number       Int             @unique @default(autoincrement())
  userId       String
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject      String
  department   String          @default("general")
  status       TicketStatus    @default(OPEN)
  priority     TicketPriority  @default(MEDIUM)
  assignedToId String?
  assignedTo   User?           @relation("AssignedTickets", fields: [assignedToId], references: [id], onDelete: SetNull)
  messages     TicketMessage[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([userId])
  @@index([status])
}

model TicketMessage {
  id          String             @id @default(cuid())
  ticketId    String
  ticket      Ticket             @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId      String
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  message     String
  attachments TicketAttachment[]
  createdAt   DateTime           @default(now())
}

// Stored in the database to stay infrastructure-free (5 MB cap per file).
model TicketAttachment {
  id        String        @id @default(cuid())
  messageId String
  message   TicketMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  filename  String
  mimeType  String
  size      Int
  data      Bytes
  createdAt DateTime      @default(now())
}

// ── Platform ────────────────────────────────────────────────────────────────

model Setting {
  key   String @id
  value String
}

enum ExtensionType {
  GATEWAY
  SERVER
}

// Installed integration: payment gateway or server-provisioning backend.
model Extension {
  id        String        @id @default(cuid())
  type      ExtensionType
  slug      String        @unique // matches a driver in src/lib/extensions
  name      String
  enabled   Boolean       @default(false)
  config    Json          @default("{}")
  products  Product[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model ApiKey {
  id          String    @id @default(cuid())
  name        String
  // sha-256 of the raw key; raw key shown once at creation
  keyHash     String    @unique
  prefix      String // first 8 chars for display
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  permissions Json      @default("[\"*\"]")
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())
}

model EmailTemplate {
  key       String   @id // e.g. invoice_created, service_activated
  subject   String
  body      String // supports {{placeholders}}
  enabled   Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

model EmailLog {
  id        String   @id @default(cuid())
  to        String
  subject   String
  status    String // sent | failed
  error     String?
  createdAt DateTime @default(now())
}

// ── Affiliates ──────────────────────────────────────────────────────────────

enum CommissionType {
  PERCENT
  FIXED
}

enum CommissionStatus {
  EARNED
  PAID
}

model Affiliate {
  id          String                @id @default(cuid())
  userId      String                @unique
  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  code        String                @unique
  balance     Decimal               @default(0) @db.Decimal(12, 2) // base currency
  totalEarned Decimal               @default(0) @db.Decimal(12, 2)
  visits      Int                   @default(0)
  createdAt   DateTime              @default(now())
  commissions AffiliateCommission[]
  referred    User[]                @relation("ReferredUsers")
}

model AffiliateCommission {
  id             String           @id @default(cuid())
  affiliateId    String
  affiliate      Affiliate        @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  referredUserId String
  invoiceId      String?
  amount         Decimal          @db.Decimal(12, 2) // base currency
  status         CommissionStatus @default(EARNED)
  createdAt      DateTime         @default(now())
}

// ── OAuth2 provider (authorization-code flow) ───────────────────────────────

model OauthClient {
  id           String      @id @default(cuid())
  name         String
  clientId     String      @unique
  clientSecret String // sha-256 hash; raw shown once at creation
  redirectUris String // newline-separated exact-match URIs
  createdAt    DateTime    @default(now())
  codes        OauthCode[]
  tokens       OauthToken[]
}

model OauthCode {
  id          String      @id @default(cuid())
  codeHash    String      @unique
  clientId    String
  client      OauthClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
  userId      String
  redirectUri String
  expiresAt   DateTime
}

model OauthToken {
  id        String      @id @default(cuid())
  tokenHash String      @unique
  clientId  String
  client    OauthClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
  userId    String
  expiresAt DateTime
  createdAt DateTime    @default(now())
}

// News/blog posts shown on the public storefront.
model Announcement {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String?
  body        String
  publishedAt DateTime? // null = draft
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String
  targetType String?
  targetId   String?
  ip         String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([createdAt])
}
