{
  "name": "openhosting",
  "version": "0.2.0",
  "private": true,
  "description": "Open-source billing and client management platform for hosting providers. Next.js + PostgreSQL.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
